# Data — never commit
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results — keep figures/tables out of git for now
results/figures/*
results/tables/*
!results/figures/.gitkeep
!results/tables/.gitkeep

